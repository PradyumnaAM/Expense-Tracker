<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SpendWise</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="shell">
        <aside class="sidebar">
            <div class="logo">spend<span>.</span>wise</div>
            <nav class="nav">
                <a href="@Url.Action("Index","Home")" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"active":"")">
                    <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M2 11l8-8 8 8v7a1 1 0 01-1 1H3a1 1 0 01-1-1v-7z"/></svg>
                    Dashboard
                </a>
                <a href="@Url.Action("Index","Expenses")" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Expenses"?"active":"")">
                    <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M4 4h12a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2zm0 4v6h12V8H4zm2 2h3v2H6v-2z"/></svg>
                    Transactions
                </a>
                <a href="@Url.Action("Index","Reports")" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString()=="Reports"?"active":"")">
                    <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M2 10a8 8 0 018-8v8h8a8 8 0 11-16 0z"/><path d="M12 2.252A8.014 8.014 0 0117.748 8H12V2.252z"/></svg>
                    Reports
                </a>
                <a href="@Url.Action("Create","Expenses")" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString()=="Create"?"active":"")">
                    <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"/></svg>
                    Add Transaction
                </a>
            </nav>
            <div class="sidebar-bottom">
                <a href="@Url.Action("Settings","Account")" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString()=="Settings"?"active":"")">
                    <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/></svg>
                    Settings
                </a>
                <div class="user-row">
                    <div class="avatar">@(User.Identity?.Name?.Substring(0,2).ToUpper() ?? "??")</div>
                    <div class="user-info">
                        <span class="user-name">@User.Identity?.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                            <button type="submit" class="logout-btn">Sign out</button>
                        </form>
                    </div>
                </div>
            </div>
        </aside>

        <main class="main-content">
            @if (TempData["Success"] != null)
            {
                <div class="toast toast-success">@TempData["Success"]</div>
            }
            @RenderBody()
        </main>
    </div>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
