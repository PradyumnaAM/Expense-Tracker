@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "_AuthLayout";
}

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo">spend<span>.</span>wise</div>
        <h1 class="auth-title">Create account</h1>
        <p class="auth-sub">Start tracking your finances today</p>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="DisplayName" class="form-label">Your Name</label>
                <input asp-for="DisplayName" class="form-input" placeholder="Pradyumna" autocomplete="name" />
                <span asp-validation-for="DisplayName" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-input" type="email" placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Password <span class="optional">(min 8 characters)</span></label>
                <input asp-for="Password" class="form-input" type="password" placeholder="••••••••" autocomplete="new-password" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-input" type="password" placeholder="••••••••" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-full" style="margin-top:8px">Create Account</button>
        </form>

        <p class="auth-footer">Already have an account? <a href="@Url.Action("Login")">Sign in →</a></p>
    </div>
</div>
