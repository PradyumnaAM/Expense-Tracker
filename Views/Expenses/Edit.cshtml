@model ExpenseCreateViewModel
@{
    ViewData["Title"] = "Edit Transaction";
    var id = ViewContext.RouteData.Values["id"];
}

<div class="page-header">
    <div>
        <h1 class="page-title">Edit Transaction</h1>
        <p class="page-sub">Update the details below</p>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-ghost">← Back</a>
</div>

<div class="card form-card">
    <form asp-action="Edit" asp-route-id="@id" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="validation-summary"></div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Type" class="form-label">Type</label>
                <div class="type-toggle">
                    <label class="type-opt">
                        <input type="radio" asp-for="Type" value="Expense" />
                        <span>Expense</span>
                    </label>
                    <label class="type-opt">
                        <input type="radio" asp-for="Type" value="Income" />
                        <span>Income</span>
                    </label>
                </div>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group flex-2">
                <label asp-for="Description" class="form-label">Description</label>
                <input asp-for="Description" class="form-input" placeholder="e.g. Grocery run, Netflix, Rent…" autocomplete="off" />
                <span asp-validation-for="Description" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Amount" class="form-label">Amount ($)</label>
                <input asp-for="Amount" class="form-input" type="number" step="0.01" min="0.01" placeholder="0.00" />
                <span asp-validation-for="Amount" class="field-error"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Category" class="form-label">Category</label>
                <select asp-for="Category" class="form-select"
                        asp-items="Html.GetEnumSelectList<ExpenseCategory>()"></select>
                <span asp-validation-for="Category" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Date" class="form-label">Date</label>
                <input asp-for="Date" class="form-input" type="date" />
                <span asp-validation-for="Date" class="field-error"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Notes" class="form-label">Notes <span class="optional">(optional)</span></label>
            <textarea asp-for="Notes" class="form-input form-textarea" rows="3" placeholder="Any extra context…"></textarea>
        </div>

        <div class="form-group">
            <label class="checkbox-label">
                <input asp-for="IsRecurring" type="checkbox" class="form-checkbox" />
                <span>Mark as recurring (monthly)</span>
            </label>
        </div>

        <div class="form-actions">
            <a href="@Url.Action("Index")" class="btn btn-ghost">Cancel</a>
            <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.type-opt input').forEach(r => {
            r.addEventListener('change', () => {
                document.querySelectorAll('.type-opt').forEach(o => o.classList.remove('selected'));
                r.closest('.type-opt').classList.add('selected');
            });
            if (r.checked) r.closest('.type-opt').classList.add('selected');
        });
    </script>
}
